APP_ENV=local
LOG_LEVEL=INFO

# Postgres (별도 DB 권장: Prisma 스키마와 분리)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/forum_monitor

# Discourse
DISCOURSE_BASE_URL=https://forum.playinzoi.com
DISCOURSE_USER_AGENT=PlayInZOIForumMonitor/0.1 (+contact:admin@example.com; respectful crawl)

# HTTP/Rate limit
HTTP_TIMEOUT_SECONDS=20
REQUEST_DELAY_MS=600
MAX_DETAIL_FETCHES_PER_RUN=60

# Scheduler (테스트/로컬에서 끄려면 false)
SCHEDULER_ENABLED=true

# Polling
CATEGORY_POLL_SECONDS=600
TOPIC_LIST_POLL_SECONDS=600
HOT_DETAIL_REFRESH_SECONDS=1200
DAILY_REPORT_INTERVAL_SECONDS=3600

