# === 서버 포트 (원본 프로젝트와 동시 운영 시 반드시 다르게) ===
PORT=9080
WS_PORT=9081

# === AIMGLOBAL 필수 (PostgreSQL) ===
# 로컬 예시: createdb aimglobal 후 아래에 맞게 수정
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/aimglobal?schema=public"
JWT_SECRET=change_me_use_long_random_secret

# 스키마 적용: cd backend && npx prisma migrate deploy
# (선택) npx prisma db seed

# 로컬에서 네이버 카페 크롤러(일반/클랜/백필 워커) 끄기: true | 1 | yes
# DISABLE_NAVER_CAFE_WORKERS=true

# === playinzoi Discourse 포럼 수집 (카테고리별 latest + 토픽 JSON → RawLog → 자동 이슈 승격) ===
# 켜려면 true | 1 | yes (기본: 미기동)
# DISCOURSE_INZOI_ENABLED=true
# DISCOURSE_INZOI_BASE_URL=https://forum.playinzoi.com
# 사이클 간 대기(ms), 요청 간 대기(ms), 한 번에 최대 토픽 상세 fetch 수 (백필 시 상태는 MonitoringConfig discourse.inzoi.scanState)
# DISCOURSE_INZOI_POLL_MS=300000
# DISCOURSE_INZOI_REQUEST_DELAY_MS=600
# DISCOURSE_INZOI_MAX_TOPIC_FETCHES_PER_RUN=40
# 선택: User-Agent
# DISCOURSE_INZOI_USER_AGENT=
# 본문에 이미지가 있으면 Playwright로 첫 글 .cooked 스크린샷 (기본 on, 끄려면 false)
# DISCOURSE_INZOI_SCREENSHOTS=true

# Line Messaging API 설정 (미사용 시 플레이스홀더 그대로 두거나 비워 두면 연결 테스트·경고 생략)
LINE_CHANNEL_ACCESS_TOKEN=여기에_Channel_Access_Token_입력
LINE_CHANNEL_SECRET=여기에_Channel_Secret_입력

# === Partner Video Archiving (YouTube / TikTok / 인스타그램) ===
# YouTube Data API v3 Key (YouTube 메타데이터 수집용)
YOUTUBE_API_KEY=your_youtube_api_key_here

# TikTok (Apify 기반 수집)
TIKTOK_APIFY_API_TOKEN=your_apify_api_token_here
# 선택: Apify Actor ID (기본값: gratenes/tiktok-media-and-metadata-retriever)
TIKTOK_APIFY_ACTOR_ID=gratenes/tiktok-media-and-metadata-retriever

# 인스타그램 (Apify 기반 수집. TIKTOK_APIFY_API_TOKEN 재사용 가능)
INSTAGRAM_APIFY_API_TOKEN=your_apify_api_token_here
# 선택: Apify Actor ID (기본값: apify/instagram-post-scraper)
INSTAGRAM_APIFY_ACTOR_ID=apify/instagram-post-scraper

# 파트너 영상 아카이빙 → Discord 알림 (선택, 설정 시 수집 완료 후 Embed 전송, 중복 전송 방지)
PARTNER_ARCHIVING_DISCORD_WEBHOOK_URL=

# === 로그인 이메일 OTP (2단계 인증) ===
# true 이고 User.role 이 AGENT 인 경우에만 OTP 적용 (ADMIN/LEAD/VIEWER 는 비밀번호만으로 즉시 로그인)
# false 또는 미설정: 모든 역할 비밀번호만으로 즉시 로그인
LOGIN_EMAIL_OTP_ENABLED=false
# OTP 코드 HMAC용 시크릿 (선택, 미설정 시 JWT_SECRET 사용)
# LOGIN_OTP_PEPPER=

# SMTP (LOGIN_EMAIL_OTP_ENABLED=true 일 때 필수)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# TLS: 465 포트일 때 또는 명시적으로 true
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="시스템관리자"<noreply@example.com>

# === 네이버 카페 이슈 댓글 주기 감시 (관리 모드) ===
# 메인 API와 워커가 같은 토큰으로 내부 콜백을 검증합니다.
ISSUE_WATCH_INTERNAL_TOKEN=change_me_for_issue_comment_watch
# true 일 때만 issueCommentWatch 워커 프로세스가 기동됩니다.
ISSUE_COMMENT_WATCH_ENABLED=false
# 선택: 워커가 메인 API를 호출할 베이스 URL (기본 http://127.0.0.1:$PORT)
# ISSUE_WATCH_INTERNAL_BASE_URL=http://127.0.0.1:9080

# === 로그·로테이션 타임존 (선택) ===
# 미설정 시 utils/logger.js 가 Asia/Seoul 로 기본 설정합니다. 다른 타임존이 필요할 때만 지정.
# TZ=Asia/Seoul

# === 로컬 개발만: SQLite 사용 시 (선택) ===
# DATABASE_URL="file:./prisma/dev.db"
