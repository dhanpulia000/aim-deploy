{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://aim-deploy-production.up.railway.app/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://aim-deploy-production.up.railway.app/uploads/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
